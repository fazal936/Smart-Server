    </record>
    <record id="rule_uploaded_document_manager" model="ir.rule">
        <field name="name">Uploaded documents: manager team</field>
        <field name="model_id" ref="model_smartserve_uploaded_document"/>
        <field name="groups" eval="[(4, ref('group_smartserve_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)] if user.smartserve_can_view_all_requests else ['|', ('request_id.assigned_user_id', '=', user.id), ('request_id.assigned_user_id.smartserve_team_id', '=', user.smartserve_team_id.id)] if user.smartserve_team_id else [('request_id.assigned_user_id', '=', user.id)]</field>
    </record>
    <record id="rule_uploaded_document_admin" model="ir.rule">
        <field name="name">Uploaded documents: administrator all</field>
        <field name="model_id" ref="model_smartserve_uploaded_document"/>
        <field name="groups" eval="[(4, ref('group_smartserve_admin'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <record id="rule_request_activity_employee" model="ir.rule">
        <field name="name">Request activity: employee assignments</field>
        <field name="model_id" ref="model_smartserve_request_activity"/>
        <field name="groups" eval="[(4, ref('group_smartserve_staff'))]"/>
        <field name="domain_force">[(1, '=', 1)] if user.smartserve_can_view_all_requests else [('request_id.assigned_user_id', '=', user.id)]</field>
    </record>
    <record id="rule_request_activity_manager" model="ir.rule">
        <field name="name">Request activity: manager team</field>
        <field name="model_id" ref="model_smartserve_request_activity"/>
        <field name="groups" eval="[(4, ref('group_smartserve_manager'))]"/>
