        <field name="name">Required documents: employee assignments</field>
        <field name="model_id" ref="model_smartserve_required_document"/>
        <field name="groups" eval="[(4, ref('group_smartserve_staff'))]"/>
        <field name="domain_force">[(1, '=', 1)] if user.smartserve_can_view_all_requests else [('request_id.assigned_user_id', '=', user.id)]</field>
