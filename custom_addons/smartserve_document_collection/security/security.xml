<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="module_category_smartserve" model="ir.module.category">
        <field name="name">SmartServe</field>
        <field name="sequence">20</field>
    </record>

    <record id="group_smartserve_staff" model="res.groups">
        <field name="name">Staff</field>
        <field name="category_id" ref="module_category_smartserve"/>
    </record>

    <record id="group_smartserve_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="module_category_smartserve"/>
        <field name="implied_ids" eval="[(4, ref('group_smartserve_staff'))]"/>
    </record>

    <record id="group_smartserve_admin" model="res.groups">
        <field name="name">Administrator</field>
        <field name="category_id" ref="module_category_smartserve"/>
        <field name="implied_ids" eval="[(4, ref('group_smartserve_manager'))]"/>
        <field name="users" eval="[(4, ref('base.user_admin'))]"/>
    </record>

    <!-- Group rules are intentionally additive: Employee = assigned, Manager = team,
         Administrator = all. The optional View All toggle expands the first two. -->
    <record id="rule_request_employee" model="ir.rule">
        <field name="name">Requests: assigned to employee</field>
        <field name="model_id" ref="model_smartserve_document_request"/>
        <field name="groups" eval="[(4, ref('group_smartserve_staff'))]"/>
        <field name="domain_force">[(1, '=', 1)] if user.smartserve_can_view_all_requests else [('assigned_user_id', '=', user.id)]</field>
    </record>
    <record id="rule_request_manager" model="ir.rule">
        <field name="name">Requests: manager team</field>
        <field name="model_id" ref="model_smartserve_document_request"/>
        <field name="groups" eval="[(4, ref('group_smartserve_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)] if user.smartserve_can_view_all_requests else ['|', ('assigned_user_id', '=', False), '|', ('assigned_user_id', '=', user.id), ('assigned_user_id.smartserve_team_id', '=', user.smartserve_team_id.id)] if user.smartserve_team_id else ['|', ('assigned_user_id', '=', False), ('assigned_user_id', '=', user.id)]</field>
    </record>
    <record id="rule_request_admin" model="ir.rule">
        <field name="name">Requests: administrator all</field>
        <field name="model_id" ref="model_smartserve_document_request"/>
        <field name="groups" eval="[(4, ref('group_smartserve_admin'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <record id="rule_customer_employee" model="ir.rule">
        <field name="name">Customers: employee assignments</field>
        <field name="model_id" ref="model_smartserve_customer"/>
        <field name="groups" eval="[(4, ref('group_smartserve_staff'))]"/>
        <field name="domain_force">[(1, '=', 1)] if user.smartserve_can_view_all_requests else ['|', ('created_by_id', '=', user.id), ('request_ids.assigned_user_id', '=', user.id)]</field>
    </record>
    <record id="rule_customer_manager" model="ir.rule">
        <field name="name">Customers: manager team</field>
        <field name="model_id" ref="model_smartserve_customer"/>
        <field name="groups" eval="[(4, ref('group_smartserve_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)] if user.smartserve_can_view_all_requests else ['|', ('created_by_id', '=', user.id), '|', ('request_ids.assigned_user_id', '=', user.id), ('request_ids.assigned_user_id.smartserve_team_id', '=', user.smartserve_team_id.id)] if user.smartserve_team_id else ['|', ('created_by_id', '=', user.id), ('request_ids.assigned_user_id', '=', user.id)]</field>
    </record>
    <record id="rule_customer_admin" model="ir.rule">
        <field name="name">Customers: administrator all</field>
        <field name="model_id" ref="model_smartserve_customer"/>
        <field name="groups" eval="[(4, ref('group_smartserve_admin'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

