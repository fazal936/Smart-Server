    </record>
    <record id="rule_request_activity_admin" model="ir.rule">
        <field name="name">Request activity: administrator all</field>
        <field name="model_id" ref="model_smartserve_request_activity"/>
        <field name="groups" eval="[(4, ref('group_smartserve_admin'))]"/>
