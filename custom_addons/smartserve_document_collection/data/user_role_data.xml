<?xml version="1.0" encoding="UTF-8"?>
<odoo noupdate="1">
    <record id="role_profile_administrator" model="smartserve.role.profile">
        <field name="name">Administrator</field>
        <field name="role_code">administrator</field>
        <field name="sequence">10</field>
        <field name="description">Full SmartServe access, including users, integrations, security settings, reports and all requests.</field>
        <field name="can_create_customers">1</field>
        <field name="can_create_requests">1</field>
        <field name="can_edit_templates">1</field>
        <field name="can_reassign_requests">1</field>
        <field name="can_view_all_requests">1</field>
        <field name="can_complete_requests">1</field>
        <field name="can_export_data">1</field>
    </record>
    <record id="role_profile_manager" model="smartserve.role.profile">
        <field name="name">Manager</field>
        <field name="role_code">manager</field>
        <field name="sequence">20</field>
        <field name="description">Manages requests and workload for their team. Cannot manage administrators or core security settings.</field>
        <field name="can_create_customers">1</field>
        <field name="can_create_requests">1</field>
        <field name="can_edit_templates">1</field>
        <field name="can_reassign_requests">1</field>
        <field name="can_complete_requests">1</field>
        <field name="can_export_data">1</field>
    </record>
    <record id="role_profile_employee" model="smartserve.role.profile">
        <field name="name">Employee</field>
        <field name="role_code">employee</field>
        <field name="sequence">30</field>
        <field name="description">Works on assigned requests. Optional permissions can be enabled for specific responsibilities.</field>
        <field name="can_create_requests">1</field>
        <field name="can_complete_requests">1</field>
    </record>
</odoo>
