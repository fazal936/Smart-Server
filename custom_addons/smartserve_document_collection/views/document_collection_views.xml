<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="seq_smartserve_document_request" model="ir.sequence">
        <field name="name">SmartServe Document Request</field>
        <field name="code">smartserve.document.request</field>
        <field name="prefix">REQ/</field>
        <field name="padding">5</field>
    </record>

    <record id="view_smartserve_customer_list" model="ir.ui.view">
        <field name="name">smartserve.customer.list</field>
        <field name="model">smartserve.customer</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="company"/>
                <field name="mobile"/>
                <field name="email"/>
                <field name="request_count"/>
            </list>
        </field>
    </record>

    <record id="view_smartserve_customer_form" model="ir.ui.view">
        <field name="name">smartserve.customer.form</field>
        <field name="model">smartserve.customer</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title"><h1><field name="name"/></h1></div>
                    <group>
                        <group>
                            <field name="company"/>
                            <field name="mobile"/>
                            <field name="email"/>
                        </group>
                        <group>
                            <field name="emirates_id"/>
                            <field name="passport"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes"><field name="notes"/></page>
                        <page string="Requests"><field name="request_ids" readonly="1"/></page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_smartserve_customers" model="ir.actions.act_window">
        <field name="name">Customers</field>
        <field name="res_model">smartserve.customer</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_smartserve_service_template_list" model="ir.ui.view">
        <field name="name">smartserve.service.template.list</field>
        <field name="model">smartserve.service.template</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="due_days"/>
                <field name="whatsapp_template"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_smartserve_service_template_form" model="ir.ui.view">
        <field name="name">smartserve.service.template.form</field>
        <field name="model">smartserve.service.template</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title"><h1><field name="name"/></h1></div>
                    <group>
                        <group>
                            <field name="active"/>
                            <field name="due_days"/>
                            <field name="whatsapp_template"/>
                        </group>
                        <group>
                            <field name="folder_naming_rule"/>
                            <field name="upload_rule"/>
                        </group>
                    </group>
                    <field name="document_template_ids">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="name"/>
                            <field name="description"/>
                            <field name="required"/>
                            <field name="allowed_extensions"/>
                            <field name="max_size_mb"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_smartserve_service_templates" model="ir.actions.act_window">
        <field name="name">Service Templates</field>
        <field name="res_model">smartserve.service.template</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_smartserve_document_request_list" model="ir.ui.view">
        <field name="name">smartserve.document.request.list</field>
        <field name="model">smartserve.document.request</field>
        <field name="arch" type="xml">
            <list decoration-danger="state == 'rejected'" decoration-success="state == 'completed'" decoration-warning="state in ('waiting', 'submitted', 'review')">
                <field name="name"/>
                <field name="title"/>
                <field name="customer_id"/>
                <field name="service_name"/>
                <field name="assigned_user_id"/>
                <field name="due_date"/>
                <field name="state"/>
                <field name="communication_status"/>
                <field name="uploaded_count"/>
                <field name="pending_count"/>
            </list>
        </field>
    </record>

    <record id="view_smartserve_document_request_form" model="ir.ui.view">
        <field name="name">smartserve.document.request.form</field>
        <field name="model">smartserve.document.request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_generate_request" type="object" string="Generate Request" class="btn-primary" invisible="state in ('completed', 'revoked')"/>
                    <button name="action_start_review" type="object" string="Start Review" invisible="state not in ('submitted', 'waiting')"/>
                    <button name="action_request_more_documents" type="object" string="Request More Documents" invisible="state in ('draft', 'completed', 'revoked')"/>
                    <button name="action_mark_completed" type="object" string="Complete" class="btn-success" invisible="state == 'completed'"/>
                    <button name="action_mark_rejected" type="object" string="Reject" invisible="state == 'rejected'"/>
                    <button name="action_revoke_upload_link" type="object" string="Revoke Link" invisible="upload_revoked"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,waiting,submitted,review,completed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                        <h2><field name="title" placeholder="Request Title"/></h2>
                    </div>
                    <group>
                        <group string="Customer">
                            <field name="customer_id"/>
                            <field name="customer_name" readonly="1"/>
                            <field name="email" readonly="1"/>
                            <field name="mobile" readonly="1"/>
                        </group>
                        <group string="Request">
                            <field name="template_id"/>
                            <field name="service_name"/>
                            <field name="assigned_user_id"/>
                            <field name="due_date"/>
                        </group>
                    </group>
                    <group string="Secure Upload">
                        <field name="upload_url" readonly="1"/>
                        <field name="upload_expires_at"/>
                        <field name="allow_multiple_uploads"/>
                        <field name="upload_revoked" readonly="1"/>
                    </group>
                    <group string="SharePoint and Communication">
                        <field name="sharepoint_folder_id" readonly="1"/>
                        <field name="sharepoint_folder_url" readonly="1"/>
                        <field name="communication_status" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Required Documents">
                            <field name="required_document_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="description"/>
                                    <field name="required"/>
                                    <field name="allowed_extensions"/>
                                    <field name="max_size_mb"/>
                                    <field name="upload_status"/>
                                    <field name="review_status"/>
                                    <field name="sharepoint_file_id"/>
                                </list>
                            </field>
                        </page>
                        <page string="Uploaded Metadata">
                            <field name="uploaded_document_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="required_document_id"/>
                                    <field name="storage_provider"/>
                                    <field name="storage_file_id"/>
                                    <field name="storage_url"/>
                                    <field name="mimetype"/>
                                    <field name="file_size"/>
                                    <field name="review_status"/>
                                </list>
                            </field>
                        </page>
                        <page string="Internal Notes"><field name="internal_notes"/></page>
                        <page string="Activity Timeline">
                            <field name="activity_ids" readonly="1">
                                <list>
                                    <field name="create_date"/>
                                    <field name="activity_type"/>
                                    <field name="summary"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_smartserve_document_request_search" model="ir.ui.view">
        <field name="name">smartserve.document.request.search</field>
        <field name="model">smartserve.document.request</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="title"/>
                <field name="customer_id"/>
                <field name="service_name"/>
                <filter string="Pending Requests" name="pending" domain="[('state', 'in', ['draft', 'waiting'])]"/>
                <filter string="Pending Review" name="review" domain="[('state', 'in', ['submitted', 'review'])]"/>
                <filter string="Completed" name="completed" domain="[('state', '=', 'completed')]"/>
                <filter string="Expiring Requests" name="expiring" domain="[('state', 'in', ['waiting', 'submitted', 'review'])]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Assigned Staff" name="group_staff" context="{'group_by': 'assigned_user_id'}"/>
                    <filter string="Service" name="group_service" context="{'group_by': 'service_name'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_smartserve_document_requests" model="ir.actions.act_window">
        <field name="name">Requests</field>
        <field name="res_model">smartserve.document.request</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_smartserve_document_request_search"/>
    </record>

    <record id="action_smartserve_pending_review" model="ir.actions.act_window">
        <field name="name">Pending Review</field>
        <field name="res_model">smartserve.document.request</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', 'in', ['submitted', 'review'])]</field>
    </record>

    <record id="action_smartserve_completed_requests" model="ir.actions.act_window">
        <field name="name">Completed</field>
        <field name="res_model">smartserve.document.request</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', '=', 'completed')]</field>
    </record>

    <record id="view_smartserve_uploaded_document_list" model="ir.ui.view">
        <field name="name">smartserve.uploaded.document.list</field>
        <field name="model">smartserve.uploaded.document</field>
        <field name="arch" type="xml">
            <list decoration-danger="review_status == 'rejected'" decoration-success="review_status == 'approved'">
                <field name="name"/>
                <field name="request_id"/>
                <field name="required_document_id"/>
                <field name="storage_provider"/>
                <field name="storage_file_id"/>
                <field name="uploaded_at"/>
                <field name="review_status"/>
            </list>
        </field>
    </record>

    <record id="view_smartserve_uploaded_document_form" model="ir.ui.view">
        <field name="name">smartserve.uploaded.document.form</field>
        <field name="model">smartserve.uploaded.document</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_approve" type="object" string="Approve" class="btn-primary" invisible="review_status == 'approved'"/>
                    <button name="action_reject" type="object" string="Reject" invisible="review_status == 'rejected'"/>
                    <field name="review_status" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="request_id"/>
                        <field name="required_document_id"/>
                        <field name="storage_provider"/>
                        <field name="storage_file_id"/>
                        <field name="storage_url"/>
                        <field name="filename"/>
                        <field name="mimetype"/>
                        <field name="file_size"/>
                    </group>
                    <group string="Staff Notes"><field name="staff_notes"/></group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_smartserve_uploaded_documents" model="ir.actions.act_window">
        <field name="name">Uploaded Documents</field>
        <field name="res_model">smartserve.uploaded.document</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_smartserve_document_collection_root" name="SmartServe" sequence="20" groups="smartserve_document_collection.group_smartserve_staff"/>
    <menuitem id="menu_smartserve_document_dashboard" name="Dashboard" parent="menu_smartserve_document_collection_root" action="action_smartserve_document_requests" sequence="10" groups="smartserve_document_collection.group_smartserve_staff"/>
    <menuitem id="menu_smartserve_customers" name="Customers" parent="menu_smartserve_document_collection_root" action="action_smartserve_customers" sequence="20" groups="smartserve_document_collection.group_smartserve_staff"/>
    <menuitem id="menu_smartserve_service_templates" name="Service Templates" parent="menu_smartserve_document_collection_root" action="action_smartserve_service_templates" sequence="30" groups="smartserve_document_collection.group_smartserve_staff"/>
    <menuitem id="menu_smartserve_document_requests" name="Requests" parent="menu_smartserve_document_collection_root" action="action_smartserve_document_requests" sequence="40" groups="smartserve_document_collection.group_smartserve_staff"/>
    <menuitem id="menu_smartserve_pending_review" name="Pending Review" parent="menu_smartserve_document_collection_root" action="action_smartserve_pending_review" sequence="50" groups="smartserve_document_collection.group_smartserve_staff"/>
    <menuitem id="menu_smartserve_uploaded_documents" name="Uploaded Documents" parent="menu_smartserve_document_collection_root" action="action_smartserve_uploaded_documents" sequence="60" groups="smartserve_document_collection.group_smartserve_staff"/>
    <menuitem id="menu_smartserve_completed_requests" name="Completed" parent="menu_smartserve_document_collection_root" action="action_smartserve_completed_requests" sequence="70" groups="smartserve_document_collection.group_smartserve_staff"/>
</odoo>
