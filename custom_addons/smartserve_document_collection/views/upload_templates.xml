<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="upload_page" name="SmartServe Secure Upload Page">
        <html lang="en">
            <head>
                <meta charset="utf-8"/>
                <meta name="viewport" content="width=device-width, initial-scale=1"/>
                <title>Document Upload</title>
                <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
                <style>
                    body { background: #f4f8fb; color: #152238; }
                    .upload-shell { min-height: 100vh; display: flex; align-items: center; padding: 32px 0; }
                    .upload-card { border: 1px solid #dce5ee; border-radius: 8px; background: #fff; box-shadow: 0 24px 70px rgba(11,45,77,.12); overflow: hidden; }
                    .upload-header { background: #0b2d4d; color: #fff; padding: 28px; }
                    .upload-logo { font-weight: 800; letter-spacing: .04em; text-transform: uppercase; color: #c69b42; }
                    .upload-body { padding: 28px; }
                    .doc-row { border: 1px solid #dce5ee; border-radius: 8px; padding: 18px; margin-bottom: 14px; }
                    .doc-row label { font-weight: 800; color: #0b2d4d; }
                    .doc-row p { margin: 6px 0 14px; color: #637083; }
                    .btn-main { background: #2f7d57; border-color: #2f7d57; font-weight: 800; padding: 12px 20px; }
                    .btn-main:hover { background: #256946; border-color: #256946; }
                    .small-muted { color: #637083; font-size: 14px; }
                    .progress { height: 10px; }
                </style>
            </head>
            <body>
                <main class="upload-shell">
                    <div class="container">
                        <div class="row justify-content-center">
                            <div class="col-lg-8 col-xl-7">
                                <div class="upload-card">
                                    <div class="upload-header">
                                        <div class="upload-logo">AL TAMKEEN CORPORATE SERVICES</div>
                                        <h1 class="h2 mt-3 mb-2" t-out="document_request.title"/>
                                        <p class="mb-0">Upload only the requested documents below. No account or password is required.</p>
                                    </div>
                                    <div class="upload-body">
                                        <t t-if="error">
                                            <div class="alert alert-danger" role="alert">
                                                <t t-out="error"/>
                                            </div>
                                        </t>
                                        <div class="row g-3 mb-4">
                                            <div class="col-md-6">
                                                <div class="small-muted">Customer Name</div>
                                                <strong t-out="document_request.customer_name"/>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="small-muted">Service Name</div>
                                                <strong t-out="document_request.service_name"/>
                                            </div>
                                            <div class="col-md-6" t-if="document_request.due_date">
                                                <div class="small-muted">Due Date</div>
                                                <strong t-out="document_request.due_date"/>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="small-muted">Request Reference</div>
                                                <strong t-out="document_request.name"/>
                                            </div>
                                        </div>

                                        <form method="post" enctype="multipart/form-data" id="smartserve-upload-form">
                                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                            <t t-foreach="document_request.required_document_ids" t-as="required_document">
                                                <div class="doc-row">
                                                    <label t-att-for="'document_%s' % required_document.id">
                                                        <t t-out="required_document.name"/>
                                                        <t t-if="required_document.required">
                                                            <span class="text-danger">*</span>
                                                        </t>
                                                    </label>
                                                    <p t-if="required_document.description" t-out="required_document.description"/>
                                                    <p t-if="not required_document.description">Please upload a clear copy of this document.</p>
                                                    <div class="small-muted mb-2">
                                                        Allowed: <t t-out="required_document.allowed_extensions"/> -
                                                        Max size: <t t-out="required_document.max_size_mb"/> MB
                                                    </div>
                                                    <input class="form-control" type="file" multiple="multiple" t-att-id="'document_%s' % required_document.id" t-att-name="'document_%s' % required_document.id"/>
                                                </div>
                                            </t>
                                            <div class="progress my-4 d-none" id="smartserve-upload-progress">
                                                <div class="progress-bar" role="progressbar" style="width: 0%"></div>
                                            </div>
                                            <div class="d-grid d-sm-flex align-items-center gap-3 mt-4">
                                                <button type="submit" class="btn btn-primary btn-main">Submit Documents</button>
                                                <span class="small-muted">Your files are sent securely to AL TAMKEEN staff for review.</span>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </main>
                <script>
                    const form = document.getElementById("smartserve-upload-form");
                    const progress = document.getElementById("smartserve-upload-progress");
                    if (form &amp;&amp; progress) {
                        form.addEventListener("submit", () =&gt; {
                            progress.classList.remove("d-none");
                            const bar = progress.querySelector(".progress-bar");
                            if (bar) {
                                bar.style.width = "65%";
                                bar.setAttribute("aria-valuenow", "65");
                            }
                        });
                    }
                </script>
            </body>
        </html>
    </template>

    <template id="upload_success_page" name="SmartServe Upload Success Page">
        <html lang="en">
            <head>
                <meta charset="utf-8"/>
                <meta name="viewport" content="width=device-width, initial-scale=1"/>
                <title>Documents Submitted</title>
                <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
                <style>
                    body { background: #f4f8fb; color: #152238; }
                    .success-shell { min-height: 100vh; display: flex; align-items: center; padding: 32px 0; }
                    .success-card { border: 1px solid #dce5ee; border-radius: 8px; background: #fff; padding: 34px; box-shadow: 0 24px 70px rgba(11,45,77,.12); }
                    .success-mark { width: 62px; height: 62px; display: inline-flex; align-items: center; justify-content: center; border-radius: 50%; background: #2f7d57; color: #fff; font-size: 32px; font-weight: 800; }
                </style>
            </head>
            <body>
                <main class="success-shell">
                    <div class="container">
                        <div class="row justify-content-center">
                            <div class="col-md-7 col-lg-6">
                                <div class="success-card text-center">
                                    <div class="success-mark mb-4">✓</div>
                                    <h1 class="h3">Documents submitted successfully</h1>
                                    <p class="text-muted mb-1">
                                        We received <strong t-out="uploaded_count"/> file(s) for
                                        <strong t-out="document_request.service_name"/>.
                                    </p>
                                    <p class="text-muted mb-0">Our staff will review them and contact you if anything else is required.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </main>
            </body>
        </html>
    </template>

    <template id="upload_invalid_page" name="SmartServe Invalid Upload Page">
        <html lang="en">
            <head>
                <meta charset="utf-8"/>
                <meta name="viewport" content="width=device-width, initial-scale=1"/>
                <title>Upload Link Unavailable</title>
                <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
                <style>
                    body { background: #f4f8fb; color: #152238; }
                    .invalid-shell { min-height: 100vh; display: flex; align-items: center; padding: 32px 0; }
                    .invalid-card { border: 1px solid #dce5ee; border-radius: 8px; background: #fff; padding: 34px; box-shadow: 0 24px 70px rgba(11,45,77,.12); }
                </style>
            </head>
            <body>
                <main class="invalid-shell">
                    <div class="container">
                        <div class="row justify-content-center">
                            <div class="col-md-7 col-lg-6">
                                <div class="invalid-card text-center">
                                    <h1 class="h3">Upload link unavailable</h1>
                                    <p class="text-muted mb-0" t-out="reason"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </main>
            </body>
        </html>
    </template>
</odoo>
